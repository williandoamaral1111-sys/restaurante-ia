generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  email         String   @unique
  passwordHash  String
  phone         String?
  logo          String?
  coverImage    String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  description   String?
  active        Boolean  @default(true)
  openingHours  Json?
  deliveryFee   Float    @default(0)
  deliveryRadius Float?
  minOrderValue Float    @default(0)
  estimatedTime Int      @default(45)
  pixKey        String?
  pixKeyType    String?
  pixMerchantName String?

  whatsappInstance String?
  whatsappStatus   String?
  whatsappPhone    String?

  categories   Category[]
  menuItems    MenuItem[]
  orders       Order[]
  customers    RestaurantCustomer[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("restaurants")
}

model Category {
  id           String     @id @default(cuid())
  name         String
  description  String?
  icon         String?
  sortOrder    Int        @default(0)
  active       Boolean    @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  createdAt    DateTime   @default(now())

  @@map("categories")
}

model MenuItem {
  id              String     @id @default(cuid())
  name            String
  description     String?
  price           Float
  images          String[]
  available       Boolean    @default(true)
  featured        Boolean    @default(false)
  sortOrder       Int        @default(0)
  preparationTime Int?

  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id])

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  addonGroups  AddonGroup[]
  orderItems   OrderItem[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("menu_items")
}

model AddonGroup {
  id          String   @id @default(cuid())
  name        String
  required    Boolean  @default(false)
  minSelect   Int      @default(0)
  maxSelect   Int      @default(1)
  sortOrder   Int      @default(0)

  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options     AddonOption[]

  @@map("addon_groups")
}

model AddonOption {
  id           String     @id @default(cuid())
  name         String
  price        Float      @default(0)
  available    Boolean    @default(true)

  addonGroupId String
  addonGroup   AddonGroup @relation(fields: [addonGroupId], references: [id], onDelete: Cascade)

  @@map("addon_options")
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  active       Boolean  @default(true)

  addresses    Address[]
  orders       Order[]
  restaurants  RestaurantCustomer[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("customers")
}

model RestaurantCustomer {
  restaurantId String
  customerId   String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  customer     Customer   @relation(fields: [customerId], references: [id])
  firstOrderAt DateTime   @default(now())
  lastOrderAt  DateTime   @default(now())
  totalOrders  Int        @default(0)

  @@id([restaurantId, customerId])
  @@map("restaurant_customers")
}

model Address {
  id           String   @id @default(cuid())
  label        String   @default("Casa")
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  lat          Float?
  lng          Float?
  isDefault    Boolean  @default(false)

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders       Order[]

  createdAt    DateTime @default(now())

  @@map("addresses")
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   Int

  restaurantId  String
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])

  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])

  addressId     String?
  address       Address?      @relation(fields: [addressId], references: [id])

  items         OrderItem[]

  status        OrderStatus   @default(RECEIVED)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  subtotal      Float
  deliveryFee   Float         @default(0)
  discount      Float         @default(0)
  total         Float

  notes         String?
  estimatedTime Int?

  pixTxId       String?
  pixQrCode     String?
  pixQrCodeText String?
  pixPaidAt     DateTime?

  source        OrderSource   @default(WEB)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Float
  totalPrice Float
  notes      String?
  addons     Json?

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  itemName   String
  itemPrice  Float

  @@map("order_items")
}

enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
  VOUCHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderSource {
  WEB
  AI_VOICE
  WHATSAPP
}
